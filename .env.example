# ===================================================
# 网易云音乐自动打卡 - 环境变量配置
# ===================================================
# 支持多账号：使用编号格式 NETEASE_COOKIE_1, NETEASE_COOKIE_2...
# 也兼容旧版单账号格式：NETEASE_COOKIE（不推荐）

# 签到密钥（必填）- 访问 /api/sign?key=xxx 时校验
AUTH_KEY=your-auth-key-here

# API 基础地址（必填）
# 需部署 NeteaseCloudMusicApiEnhanced: https://github.com/neteasecloudmusicapienhanced/api-enhanced
API_BASE_URL=https://api.example.com

# 服务器端口（可选，默认 3000）
PORT=3000

# ===================================================
# 账号配置（至少配置一个账号）
# ===================================================

# --- 账号 1 ---
NETEASE_COOKIE_1=MUSIC_U=***;
PLAYLIST_ID_1=your_playlist_id_here

# --- 账号 2（可选，取消注释并填写即可启用） ---
# NETEASE_COOKIE_2=MUSIC_U=***;
# PLAYLIST_ID_2=your_playlist_id_here

# --- 账号 3（可选） ---
# NETEASE_COOKIE_3=MUSIC_U=***;
# PLAYLIST_ID_3=your_playlist_id_here

# 按需继续添加账号 4、5、6...

# ===================================================
# 旧版单账号格式（兼容，仅在未使用编号格式时生效）
# ===================================================
# NETEASE_COOKIE=MUSIC_U=***;
# PLAYLIST_ID=your_playlist_id_here
